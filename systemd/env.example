# Copy to ~/.config/github-agent-bridge/env and chmod 600.
# Start with shadow mode. Switch to live only after replay/shadow validation.
GITHUB_AGENT_BRIDGE_MODE=shadow
GITHUB_AGENT_BRIDGE_WORKERS=4
GITHUB_AGENT_BRIDGE_REVIEW_TIMEOUT=900
GITHUB_AGENT_BRIDGE_WORK_TIMEOUT=3600
GITHUB_AGENT_BRIDGE_OPENCLAW_BIN=/home/openclaw/.nvm/versions/node/v24.14.0/bin/openclaw
GITHUB_AGENT_BRIDGE_NODE_BIN=/home/openclaw/.nvm/versions/node/v24.14.0/bin/node
GITHUB_AGENT_BRIDGE_DEFAULT_CHANNEL=telegram
GITHUB_AGENT_BRIDGE_DEFAULT_TO=43532269

# IMAP reader settings.
GITHUB_AGENT_BRIDGE_EMAIL=
GITHUB_AGENT_BRIDGE_PASSWORD=
GITHUB_AGENT_BRIDGE_IMAP_HOST=imap.gmail.com
GITHUB_AGENT_BRIDGE_IMAP_PORT=993
GITHUB_AGENT_BRIDGE_MAILBOX=INBOX
# Leave empty for shadow reads; set to --mark-seen only when this bridge owns GitHub notifications.
GITHUB_AGENT_BRIDGE_MARK_SEEN=
