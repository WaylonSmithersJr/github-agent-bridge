[Unit]
Description=GitHub Agent Bridge IMAP reader
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
Environment=GITHUB_AGENT_BRIDGE_IMAP_HOST=imap.gmail.com
Environment=GITHUB_AGENT_BRIDGE_IMAP_PORT=993
Environment=GITHUB_AGENT_BRIDGE_MAILBOX=INBOX
Environment=GITHUB_AGENT_BRIDGE_MARK_SEEN=
EnvironmentFile=-%h/.config/github-agent-bridge/env
ExecStart=%h/.local/bin/github-agent-bridge \
  --db %h/.local/state/github-agent-bridge/bridge.sqlite3 \
  --policy %h/.config/github-agent-bridge/policy.json \
  read-imap-once \
  --imap-host ${GITHUB_AGENT_BRIDGE_IMAP_HOST} \
  --imap-port ${GITHUB_AGENT_BRIDGE_IMAP_PORT} \
  --email ${GITHUB_AGENT_BRIDGE_EMAIL} \
  --password ${GITHUB_AGENT_BRIDGE_PASSWORD} \
  --mailbox ${GITHUB_AGENT_BRIDGE_MAILBOX} \
  ${GITHUB_AGENT_BRIDGE_MARK_SEEN}
